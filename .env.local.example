# Windows 本地开发配置模板：复制为 .env.local 后填写真实值，.env.local 不提交 Git。

# ---------------------------------------------------------------------------
# 后端 Django
# ---------------------------------------------------------------------------
DJANGO_ENV=dev                                              # 运行环境：本地开发固定 dev
DJANGO_SECRET_KEY=                                          # JWT 签名密钥，本地可固定值，生产必须随机生成
DJANGO_DEBUG=true                                           # 开启 Django DEBUG 模式，本地开发建议 true
DJANGO_DEBUG_LOG=true                                       # 开启 DEBUG 级别日志输出，本地开发建议 true

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
MYSQL_IP=127.0.0.1                                          # 数据库地址：本地可填 localhost / 127.0.0.1 / 局域网 IP
MYSQL_PORT=3306                                             # 数据库端口
MYSQL_DATABASE=dev_mango_server                             # 本地开发数据库名
MYSQL_USER=root                                             # 数据库用户，本地建议 root
MYSQL_PASSWORD=replace-with-local-database-password         # 数据库密码

# ---------------------------------------------------------------------------
# MinIO 对象存储
# ---------------------------------------------------------------------------
IS_MINIO=false                                              # 是否启用 MinIO，本地不使用时保持 false 即可
MINIO_ENDPOINT=127.0.0.1:9000                               # MinIO 服务地址
MINIO_ROOT_USER=replace-with-local-minio-user               # MinIO 访问账号
MINIO_ROOT_PASSWORD=replace-with-local-minio-password       # MinIO 访问密码
MINIO_BUCKET=mango-dev                                      # 本地存储桶名称
MINIO_USE_HTTPS=false                                       # 是否启用 HTTPS 访问 MinIO

# ---------------------------------------------------------------------------
# 前端 Vite 运行时配置（本地直连后端时填写完整地址）
# ---------------------------------------------------------------------------
VITE_APP_ENV=dev                                            # 前端环境标识，与 DJANGO_ENV 保持一致
VITE_APP_BASE_URL=http://127.0.0.1:8000/api                # 后端 API 完整地址
VITE_APP_SOCKET_URL=ws://127.0.0.1:8000/api/web/socket?    # WebSocket 完整地址
VITE_APP_MINIO_URL=http://127.0.0.1:8000/minio             # MinIO 文件访问代理地址
VITE_APP_MCP_SERVER_NAME=mango-test-platform                # MCP 服务注册名称
VITE_IS_INDEX_WINDOW=false                                  # 是否以独立首页窗口模式打开（影响顶部头像栏显隐）

# =====================  MCP 跨域/主机白名单 =====================
MANGO_MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,192.168.1.100:*,xxx.com:*
MANGO_MCP_ALLOWED_ORIGINS=http://127.0.0.1:*,http://localhost:*,https://xxx.com:*