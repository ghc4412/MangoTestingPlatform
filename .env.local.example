# Windows 本地开发配置模板：复制为 .env.local 后填写真实值，.env.local 不提交 Git。

# 后端运行环境：本地一般使用 dev。
DJANGO_ENV=dev
DJANGO_SECRET_KEY=replace-with-a-local-random-secret
DJANGO_DEBUG=true
DJANGO_DEBUG_LOG=true

# MySQL：本地可填 localhost / 127.0.0.1 / 局域网地址。
MYSQL_IP=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=dev_mango_server
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-local-database-password

# MinIO：不使用 MinIO 时保持 IS_MINIO=false。
IS_MINIO=false
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ROOT_USER=replace-with-local-minio-user
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
MINIO_BUCKET=mango-dev
MINIO_USE_HTTPS=false

# 前端 Vite 配置：Windows 本地直连后端时填写本机后端地址。
VITE_APP_ENV=dev
VITE_APP_BASE_URL=http://127.0.0.1:8000/api
VITE_APP_SOCKET_URL=ws://127.0.0.1:8000/api/web/socket?
VITE_APP_MINIO_URL=http://127.0.0.1:8000/minio
VITE_APP_MCP_SERVER_NAME=mango-test-platform
VITE_IS_INDEX_WINDOW=false
