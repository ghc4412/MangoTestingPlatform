# 服务器 Docker 部署配置模板：复制为 .env.docker 后填写真实值，.env.docker 不提交 Git。

# 后端运行环境：服务器通常使用 master。
DJANGO_ENV=master
DJANGO_SECRET_KEY=replace-with-a-production-random-secret
DJANGO_DEBUG=false
DJANGO_DEBUG_LOG=false

# 前端构建环境和执行器类型。
VUE_ENV=master
EXECUTOR_TYPE=linux

# MySQL：Docker 内部服务名使用 db，真实密码只写在服务器本地 .env.docker。
MYSQL_IP=db
MYSQL_PORT=3306
MYSQL_DATABASE=mango_server
MYSQL_USER=mango
MYSQL_PASSWORD=replace-with-database-password
MYSQL_ROOT_PASSWORD=replace-with-root-database-password

# MinIO：Docker 内部服务名使用 minio:9000，访问端口按服务器实际暴露配置。
IS_MINIO=true
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=replace-with-minio-user
MINIO_ROOT_PASSWORD=replace-with-minio-password
MINIO_BUCKET=mango-file
MINIO_USE_HTTPS=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# 前端浏览器访问路径：默认走 Nginx 网关相对路径。
VITE_APP_ENV=master
VITE_APP_BASE_URL=/api
VITE_APP_SOCKET_URL=/api/web/socket?
VITE_APP_MINIO_URL=/minio
VITE_APP_MCP_SERVER_NAME=mango-test-platform
VITE_IS_INDEX_WINDOW=false
