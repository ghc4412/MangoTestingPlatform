# 服务器 Docker 部署配置模板：复制为 .env.docker 后填写真实值，.env.docker 不提交 Git。

# ---------------------------------------------------------------------------
# 后端 Django
# ---------------------------------------------------------------------------
DJANGO_ENV=master                                           # 运行环境：dev / test / prod / master
DJANGO_SECRET_KEY=                                          # JWT 签名密钥，生产必须随机生成，泄露=会话劫持
DJANGO_DEBUG=false                                          # 是否开启 Django DEBUG 模式，生产必须 false
DJANGO_DEBUG_LOG=false                                      # 是否开启 DEBUG 级别日志输出，生产建议 false

# ---------------------------------------------------------------------------
# 前端构建 & 执行器
# ---------------------------------------------------------------------------
VUE_ENV=master                                              # Vite 构建环境标识：dev / master
EXECUTOR_TYPE=linux                                         # 执行器镜像类型：linux / pytest / pytest_web / web_ui / android_ui

# ---------------------------------------------------------------------------
# MySQL
# ---------------------------------------------------------------------------
MYSQL_IP=db                                                 # 数据库地址：Docker 内部使用服务名 db
MYSQL_PORT=3306                                             # 数据库端口
MYSQL_DATABASE=mango_server                                 # 业务数据库名
MYSQL_USER=mango                                            # 数据库用户
MYSQL_PASSWORD=replace-with-database-password               # 数据库密码，仅写在服务器本地 .env.docker
MYSQL_ROOT_PASSWORD=replace-with-root-database-password     # MySQL root 密码，仅初始化容器时使用

# ---------------------------------------------------------------------------
# MinIO 对象存储
# ---------------------------------------------------------------------------
IS_MINIO=true                                               # 是否启用 MinIO，true 时文件存储走 MinIO，false 时走本地磁盘
MINIO_ENDPOINT=minio:9000                                   # MinIO 服务地址：Docker 内部使用服务名:端口
MINIO_ROOT_USER=replace-with-minio-user                     # MinIO 访问账号
MINIO_ROOT_PASSWORD=replace-with-minio-password             # MinIO 访问密码
MINIO_BUCKET=mango-file                                     # 默认存储桶名称
MINIO_USE_HTTPS=false                                       # 是否启用 HTTPS 访问 MinIO
MINIO_API_PORT=9000                                         # MinIO API 端口
MINIO_CONSOLE_PORT=9001                                     # MinIO 管理控制台端口

# ---------------------------------------------------------------------------
# 前端 Vite 运行时配置（Docker 下默认走 Nginx 网关相对路径）
# ---------------------------------------------------------------------------
VITE_APP_ENV=master                                         # 前端环境标识，与 DJANGO_ENV 保持一致
VITE_APP_BASE_URL=/api                                      # 后端 API 基础路径
VITE_APP_SOCKET_URL=/api/web/socket?                        # WebSocket 连接路径
VITE_APP_MINIO_URL=/minio                                   # MinIO 文件访问代理路径
VITE_APP_MCP_SERVER_NAME=mango-test-platform                # MCP 服务注册名称
VITE_IS_INDEX_WINDOW=false                                  # 是否以独立首页窗口模式打开（影响顶部头像栏显隐）

# =====================  MCP 跨域/主机白名单 =====================
MANGO_MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*,192.168.1.100:*,xxx.com:*
MANGO_MCP_ALLOWED_ORIGINS=http://127.0.0.1:*,http://localhost:*,https://xxx.com:*